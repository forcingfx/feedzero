# FeedZero self-host configuration.
# Copy this file to `.env` and edit the values for your deployment.
# `.env` is gitignored — never commit it.

# ──────────────────────────────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────────────────────────────

# Public hostname FeedZero will be served at. Must have an A or AAAA
# DNS record pointing at this server *before* you run `feedzero up`,
# otherwise Caddy can't fetch a Let's Encrypt certificate.
#
# Examples:
#   HOSTNAME=feedzero.example.com
#   HOSTNAME=reader.alice.dev
HOSTNAME=feedzero.example.com

# ──────────────────────────────────────────────────────────────────────
# Recommended
# ──────────────────────────────────────────────────────────────────────

# Email address Caddy registers with Let's Encrypt. You'll receive
# cert-expiry reminders here if renewal ever fails. Leave blank to
# register anonymously (fine for low-volume use).
ACME_EMAIL=

# Version of the FeedZero image to run. `latest` tracks the most
# recent release; pin a specific version for production.
#
# Examples:
#   FEEDZERO_VERSION=latest
#   FEEDZERO_VERSION=v0.9.1
FEEDZERO_VERSION=latest

# Host path where encrypted vaults persist. Defaults to ./data
# (relative to the directory containing docker-compose.yml).
# Use an absolute path if you want vaults on a separate volume.
#
# Examples:
#   DATA_DIR=./data
#   DATA_DIR=/var/lib/feedzero
DATA_DIR=./data
